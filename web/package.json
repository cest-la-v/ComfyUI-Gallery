{
    "name": "comfy-ui-gallery-react",
    "private": true,
    "version": "2.6.0",
    "type": "module",
    "scripts": {
        "dev": "bun run dev.ts",
        "build": "tsc -b && bun run build.ts",
        "build:cli": "tsc -b && bun build src/main.tsx --outdir dist --entry-naming assets/comfy-ui-gallery.js --chunk-naming \"assets/comfy-ui-gallery-[name].js\" --asset-naming \"assets/comfy-ui-gallery.[ext]\" --target browser --minify",
        "build:vite": "tsc -b && vite build",
        "lint": "eslint .",
        "test": "bun test",
        "inspect": "bun web/scripts/inspect-image.ts",
        "preview": "vite preview"
    },
    "dependencies": {
        "@ant-design/icons": "^6.0.0",
        "@ant-design/v5-patch-for-react-19": "^1.0.3",
        "@emotion/react": "^11.14.0",
        "@microlink/react-json-view": "^1.26.2",
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-switch": "^1.2.6",
        "ahooks": "^3.8.5",
        "antd": "^5.25.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "file-saver": "^2.0.5",
        "jszip": "^3.10.1",
        "lucide-react": "^1.7.0",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-virtualized": "^9.22.6",
        "react-window": "^1.8.11",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.25.0",
        "@types/bun": "^1.3.11",
        "@types/file-saver": "^2.0.7",
        "@types/react": "^19.1.2",
        "@types/react-dom": "^19.1.2",
        "@types/react-virtualized": "^9.22.2",
        "@types/react-window": "^1.8.8",
        "@vitejs/plugin-react": "^4.4.1",
        "bun-plugin-tailwind": "^0.1.2",
        "eslint": "^9.25.0",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.19",
        "globals": "^16.0.0",
        "tailwindcss": "^4.2.2",
        "typescript": "~5.8.3",
        "typescript-eslint": "^8.30.1",
        "vite": "^6.3.5"
    }
}
